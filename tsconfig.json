{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": "dist",
    "rootDir": ".",
    "baseUrl": ".",
    "paths": {
      "@workspace/db": ["lib/db/src/index.ts"],
      "@workspace/db/*": ["lib/db/src/*"]
    },
    "esModuleInterop": true,
    "skipLibCheck": true
  },
  "include": ["lib/db/src/**/*", "src/**/*"]
}
